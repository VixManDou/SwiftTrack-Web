<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Resultado de Rastreo - SwiftTrack</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 p-6">
    <div class="max-w-md mx-auto bg-white p-6 rounded-lg shadow-md border-t-4 border-blue-600">
        <h1 class="text-2xl font-bold mb-4">Información de Guía</h1>
        
        <% if (paquete) { %>
            <div class="space-y-3">
                <p><strong>Folio:</strong> <span class="font-mono text-blue-600 font-bold"><%= paquete.folio %></span></p>
                <p><strong>Destino:</strong> <%= paquete.destino %></p>
                <p><strong>Peso:</strong> <%= paquete.peso %> kg</p>
                <div class="p-3 bg-blue-50 rounded font-bold text-center">
                    Estatus: <span class="text-blue-700"><%= paquete.estado %></span>
                </div>
            </div>
        <% } else { %>
            <p class="text-red-500 font-bold">No se encontró ningún paquete con el folio: "<%= query %>"</p>
        <% } %>
        
        <a href="/" class="block text-center mt-6 text-blue-600 hover:underline">← Volver al inicio</a>
    </div>
</body>
</html>